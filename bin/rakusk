#!/usr/bin/env raku
use v6;
use Rakusk;

use Rakusk::Log;

my $VERSION = "2.0.0";

#| rakusk: Raku-based x86 Assembler
sub MAIN(
    *@args,
    Str :$enc,                   #= ソースコードのエンコーディング (utf8, cp932等)
    Bool :v(:$version) = False,  #= バージョンとライセンス情報を表示する
    Bool :d(:$debug) = False,    #= デバッグログを出力する
    Bool :i(:$show-info) = False #= 命令のサイズと情報を表示
) {
    if $version {
        say "rakusk $VERSION";
        print Q:to/EOF/;
Copyright (C) 2026 Cline (Original: 2024 idiotpanzer@gmail.com)
ライセンス GPLv3+: GNU GPL version 3 or later <http://gnu.org/licenses/gpl.html>.
This is free software: you are free to change and redistribute it.
There is NO WARRANTY, to the extent permitted by law.

Thank you osask project !
EOF
        exit 0;
    }

    if @args.elems < 2 {
        note "usage:  [--help | -v] source [object/binary] [list]";
        exit 16;
    }

    my $assembly-src = @args[0];
    my $assembly-dst = @args[1];

    if $debug {
        set-level(DEBUG);
    }

    my $code;
    my $used-enc = $enc // 'utf8';

    if $assembly-src.IO.f {
        if $enc.defined {
            try {
                $code = $assembly-src.IO.slurp(:enc($enc));
                CATCH {
                    default {
                        # Raku本体がサポートしていない場合、iconvを試みる
                        $code = read-with-iconv($assembly-src, $enc);
                    }
                }
            }
        } else {
            # 自動判別（UTF-8 -> CP932）
            try {
                $code = $assembly-src.IO.slurp(:enc<utf8>);
                $used-enc = 'utf8';
                CATCH {
                    default {
                        try {
                            $code = $assembly-src.IO.slurp(:enc<cp932>);
                            $used-enc = 'cp932';
                            CATCH {
                                default {
                                    # iconvを試みる
                                    $code = read-with-iconv($assembly-src, 'cp932');
                                    $used-enc = 'cp932';
                                }
                            }
                        }
                    }
                }
            }
        }
    } else {
        note "RAKUSK : can't open $assembly-src";
        exit 17;
    }

    if $code.trim eq '' {
        note "No input code provided.";
        exit 1;
    }

    say "source: $assembly-src, object: $assembly-dst (encoding: $used-enc)";

    # 出力バイナリのエンコーディング設定。DB "文字列" 等で使用される。
    # Rakuの内部文字列をバイナリ化する際のエンコーディングを指定する。
    my $res = assemble($code, :enc($used-enc));
    my $bin = $res.binary;

    if $show-info {
        say "\n--- Instruction Information ---";
        for $res.listing -> $item {
            # say "Item keys: " ~ $item.keys.join(', ');
            next unless $item<bin>;
            printf "0x%04X: [%-20s] %-12s size=%d  %s\n",
            $item<pc>,
            $item<bin>.list.map({ .fmt('%02X') }).join(' '),
            $item<type>,
            $item<size>,
            $item<node>.mnemonic;
        }
        say "-------------------------------\n";
    }

    if match_success($bin) {
        $assembly-dst.IO.spurt($bin);
        # say "Successfully assembled to $assembly-dst";
        # say "Binary (Hex): " ~ $bin.list.map({ .fmt('%02X') }).join(' ');
        
        # 検証（ndisasmが利用可能な場合）
        if $show-info && shell("which ndisasm > /dev/null 2>&1").exitcode == 0 {
            say "--- Disassembly Check ---";
            shell "ndisasm -b16 $assembly-dst";
        }
    } else {
        note "Assembly failed!";
        exit 1;
    }
}

sub match_success($val) {
    return $val.defined && $val.elems > 0;
}

sub read-with-iconv($path, $enc) {
    my $proc = run 'iconv', '-f', $enc, '-t', 'utf-8', $path, :out, :err;
    my $content = $proc.out.slurp(:close);
    if $proc.exitcode != 0 {
        my $err = $proc.err.slurp(:close);
        note "RAKUSK : iconv failed for $path with encoding $enc: $err";
        exit 1;
    }
    return $content;
}
