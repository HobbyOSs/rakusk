use v6;
use Test;
use Rakusk;
use lib 't';
use TestHelper;

plan 1;

subtest "harib00a (Day 03)" => {
    my $asm = q:to/ASM/;
        ORG     0x7c00
        JMP     entry
        DB      0x90
        DB      "HARIBOTE"
        DW      512
        DB      1
        DW      1
        DB      2
        DW      224
        DW      2880
        DB      0xf0
        DW      9
        DW      18
        DW      2
        DD      0
        DD      2880
        DB      0, 0, 0x29
        DD      0xffffffff
        DB      "HARIBOTEOS "
        DB      "FAT12   "
        RESB    18

entry:
        MOV     AX, 0
        MOV     SS, AX
        MOV     SP, 0x7c00
        MOV     DS, AX

        MOV     AX, 0x0820
        MOV     ES, AX
        MOV     CH, 0
        MOV     DH, 0
        MOV     CL, 2

        MOV     AH, 0x02
        MOV     AL, 1
        MOV     BX, 0
        MOV     DL, 0x00
        INT     0x13
        JC      error

fin:
        HLT
        JMP     fin

error:
        MOV     SI, msg
putloop:
        MOV     AL, [SI]
        ADD     SI, 1
        CMP     AL, 0
        JE      fin
        MOV     AH, 0x0e
        MOV     BX, 15
        INT     0x10
        JMP     putloop
msg:
        DB      0x0a, 0x0a
        DB      "load error"
        DB      0x0a
        DB      0

        RESB    0x7dfe-$

        DB      0x55, 0xaa
ASM

    my $expected = Buf.new(
        
        0xeb, 0x4e,
        0x90,
        0x48, 0x41, 0x52, 0x49, 0x42, 0x4f, 0x54, 0x45, # "HARIBOTE"
        0x00, 0x02,
        0x01,
        0x01, 0x00,
        0x02,
        0xe0, 0x00,
        0x40, 0x0b,
        0xf0,
        0x09, 0x00,
        0x12, 0x00,
        0x02, 
        0x00,
        0x00, 0x00, 0x00, 0x00,
        0x40, 0x0b, 0x00, 0x00,
        0x00, 0x00, 0x29,
        0xff, 0xff, 0xff, 0xff,
        0x48, 0x41, 0x52, 0x49, 0x42, 
        0x4f, 0x54, 0x45, 0x4f, 0x53, 0x20, # "HARIBOTEOS "
        0x46, 0x41, 0x54, 0x31, 0x32, 0x20, 0x20, 0x20, # "FAT12   "
        (0x00 xx 18),
        0xb8, 0x00, 
        0x00,
        0x8e, 0xd0,
        0xbc, 0x00, 0x7c,
        0x8e, 0xd8,
        0xb8, 0x20, 0x08,
        0x8e, 0xc0,
        0xb5, 0x00,
        0xb6, 0x00,
        0xb1, 0x02,
        0xb4, 0x02,
        0xb0, 0x01,
        0xbb, 0x00, 0x00,
        0xb2, 0x00,
        0xcd, 
        0x13,
        0x72, 0x03,
        0xf4,
        0xeb, 0xfd,
        0xbe, 0x8a, 0x7c,
        0x8a, 0x04,
        0x83, 0xc6, 0x01,
        0x3c, 0x00,
        0x74, 0xf1,
        0xb4, 0x0e,
        0xbb, 0x0f, 0x00,
        0xcd, 0x10,
        0xeb, 0xee,
        0x0a, 0x0a,
        0x6c, 
        0x6f, 0x61, 0x64, 0x20, 0x65, 0x72, 0x72, 0x6f, 0x72,
        0x0a,
        0x00,
        (0x00 xx 358),
        0x55, 0xaa
    
    );

    my $actual = assemble($asm);
    is-binary($actual, $expected, "Harib00a bootstrap sequence");
}

done-testing;
